# ============================================
# OPTIMAL BREAKS — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# SECURITY:
# - The anon key is safe to expose client-side (it's rate-limited by RLS)
# - NEVER put service_role key in NEXT_PUBLIC_ variables
# - Enable RLS on all tables in Supabase dashboard
# ============================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
